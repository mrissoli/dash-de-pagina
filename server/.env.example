PORT=3001

# ==========================================================
# Crendenciais do Google Analytics 4 (Data API)
# ==========================================================
# O GA4 exige uma Google Cloud Service Account.
# Baixe o arquivo JSON com as credenciais da Service Account e referencie o caminho dele abaixo.
# Exemplo: ./minhas-credenciais.json (Mantenha FORA de commits via .gitignore)

GOOGLE_APPLICATION_CREDENTIALS="caminho/para/seu/arquivo-credenciais.json"

# Seu ID da Propriedade do GA4. 
# Encontrado no Admin > Configurações da Propriedade (é apenas numérico, sem "G-").
GA4_PROPERTY_ID="SEU_PROPERTY_ID_AQUI"


# ==========================================================
# Crendenciais do Microsoft Clarity
# ==========================================================
# Para automatizar dados do Clarity como Visualizações ativas ou Webhooks de exportação.

CLARITY_API_TOKEN="SEU_TOKEN_API_DO_CLARITY_AQUI"
CLARITY_PROJECT_ID="SEU_PROJECT_ID_DO_CLARITY_AQUI"
